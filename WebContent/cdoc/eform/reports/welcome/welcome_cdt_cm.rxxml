						<font size="8"/>
					</textElement>
					<text><![CDATA[본 계약서에 의한 대부조건은 다음과 같다.]]></text>
				</staticText>
				<textField>
					<reportElement uuid="e099586c-18c1-46ca-b112-7b80df1dee52" mode="Transparent" x="260" y="501" width="295" height="15" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5"/>
					<textElement textAlignment="Justified" verticalAlignment="Middle" markup="none">
						<font size="8" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[null == $F{CustName} ? "(          고객님)" : "("+$F{CustName}+" 고객님)"]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="516" width="555" height="11" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5" rightPadding="0">
						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.0" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.0" lineColor="#E36C0A"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font size="7" isBold="true"/>
					</textElement>
					<text><![CDATA[<굵은 박스 내 자필기재>좌측 인쇄된 대부조건을 굵은 박스 내 흐린 글씨 위에 자필기재 합니다.]]></text>
				</staticText>
