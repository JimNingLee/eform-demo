				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="190" width="391" height="38" forecolor="#000000" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<topPen lineWidth="0.75" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.75" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
						<rightPen lineWidth="0.0" lineColor="#E36C0A"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font size="8"/>
					</textElement>
					<text><![CDATA[본인은 본 계약에 따른 대부한도액을 상한으로 하여 웰컴크레디라인대부㈜(이하 “회사”라 함)가 결정하는 이용한도액의 범위 내에서 반복적으로 이루어지는 대부거래계약을 체결함에 있어 대부거래 약관이 적용됨을 승인하고 다음 대부거래 계약 각 조항을 확약하며 성실히 이행하겠습니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="228" width="391" height="27" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.75" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
						<rightPen lineWidth="0.0" lineColor="#E36C0A"/>
					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font size="8"/>
					</textElement>
					<text><![CDATA[계약서 및 대부거래약관의 중요한 내용에 대해 충분한 설명을 들었으며, 계약서 및 대부거래약관을 확실히 수령하였습니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="255" width="391" height="17" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.75" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
						<rightPen lineWidth="0.0" lineColor="#E36C0A"/>
					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font size="8"/>
					</textElement>
					<text><![CDATA[원리금 납입 기일안내와 대부관련 안내 등 SMS문자 수신 및 e메일서비스에 동의합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="272" width="391" height="16" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.75" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
						<rightPen lineWidth="0.0" lineColor="#E36C0A"/>
					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font size="8"/>
					</textElement>
					<text><![CDATA[대부중개업자가 중개수수료를 고객으로부터 받는 것이 불법임을 설명 들었습니다.]]></text>
				</staticText>
