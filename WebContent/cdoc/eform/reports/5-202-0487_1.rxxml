						<bottomPen lineWidth="2.5" lineColor="#615BB1"/>
					</box>
					<textElement textAlignment="Right">
						<font isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA["신청일자 : " + StringUtils.format($F{EF_DATE},"@@@@년 @@월 @@일") + "          신청인(본인) : " + $F{item1}]]></textFieldExpression>
				</textField>
