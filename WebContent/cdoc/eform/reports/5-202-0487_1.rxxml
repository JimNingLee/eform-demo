					<reportElement uuid="9c0a9d99-481e-41bc-a16c-f6d0862f8d76" style="colorback" mode="Opaque" x="10" y="634" width="172" height="15">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
