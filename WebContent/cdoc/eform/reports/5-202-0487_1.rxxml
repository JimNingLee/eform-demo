				<textField>
					<reportElement uuid="038488fc-53ba-4d2e-b764-59b98c4de565" style="colorback" x="470" y="529" width="100" height="13">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<bottomPen lineWidth="0.0"/>
