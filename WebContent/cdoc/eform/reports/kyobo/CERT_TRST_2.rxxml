					<textElement textAlignment="Center" markup="none">
						<font size="9"/>
					</textElement>
					<text><![CDATA[귀하의 이익계산서는 위와 같음을 증명합니다.]]></text>
				</staticText>
				<textField isBlankWhenNull="true">
