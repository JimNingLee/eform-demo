					<textElement textAlignment="Center" markup="none">
						<font size="9"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA[""]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement style="styleM" x="4" y="159" width="680" height="12"/>
					<textElement textAlignment="Left" markup="none">
						<font size="9"/>
					</textElement>
					<text><![CDATA[상기 지급세액은 이분기 원천징수시 계산된 신탁보수금액과 해지시 신탁보수금액을 합산하여 차감한 지급금액입니다.]]></text>
				</staticText>
				<staticText>
