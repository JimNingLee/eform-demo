				<staticText>
					<reportElement uuid="7bedfebe-7f0e-42e8-b167-c4222601b214" mode="Opaque" x="1" y="92" width="83" height="18" isPrintInFirstWholeBand="true" backcolor="#EEEFEE"/>
					<box>
						<pen lineWidth="1.0"/>
						<topPen lineWidth="1.0"/>
						<leftPen lineWidth="1.0"/>
						<bottomPen lineWidth="1.0"/>
