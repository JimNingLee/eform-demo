				<textField>
					<reportElement uuid="bfd5bfd2-cd60-4c63-a094-eb2dbf70928d" style="paddingL" x="410" y="384" width="117" height="97" isPrintInFirstWholeBand="true"/>
					<box>
						<pen lineWidth="1.0"/>
						<topPen lineWidth="1.0"/>
						<leftPen lineWidth="1.0"/>
						<bottomPen lineWidth="1.0"/>
						<rightPen lineWidth="1.0"/>
					</box>
					<textElement verticalAlignment="Middle" markup="none">
						<font size="9"/>
					</textElement>
					<textFieldExpression><![CDATA[( $F{pTpdNm} == "MMT" ? "□ 부동산의 매입 및 개발\n□ 장내파생상품\n□ 장외파생상품\n□ 대출금\n□ 기타" : "□ 부동산의 매입 및 개발\n□ 장내파생상품\n□ 장외파생상품\n□ 대출금\n■ 기타" )]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement uuid="617cebd6-da7c-4ea1-b10c-4d5ed6a42c3f" style="paddingL" x="7" y="481" width="520" height="93" isPrintInFirstWholeBand="true"/>
					<textElement verticalAlignment="Middle" markup="html">
						<font size="9"/>
					</textElement>
					<text><![CDATA[** 정기예금을 운용대상으로 하는 경우 갑은 신탁계약기간 종료일 이전에 만기가 도래하는 정기예금을 지정하여야 하며,
추후 갑이 중도해지 하고자 하는 경우 당해 신탁재산으로 운용중인 정기예금을 만기전에 해지할 수 있으며, 이로 인한
이자 수익의 감소 등 제반 불이익은 갑에게 귀속합니다.
** 신탁계약의 종료에도 불구하고 기업어음증권의 경우 부도발생시 해당 지분만큼 실물로 지급하는 것이 곤란할 수
있으며, 분할 후 실물로 지급을 받는다 하더라도 기업어음증권의 권리자로서 정상적인 권리행사가 어려울 수 있습니다.
※ 고객이 지정한 방법대로 운용할 수 없는 잔액이 있는 경우에는 <font color="red">금융투자업규정 제4-85조 제3항에 따라 을의 고유계정에 대한
일시적인 자금 대여 및 자금중개회사의 중개를 거쳐 행하는 단기자금 대여의 방법으로</font> 운용할 수 있다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="5d8333df-da5e-496a-b73d-138a1aeca032" style="paddingL" x="1" y="579" width="534" height="12" isPrintInFirstWholeBand="true"/>
