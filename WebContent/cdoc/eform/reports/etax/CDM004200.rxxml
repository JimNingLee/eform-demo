					<reportElement uuid="446541b4-a576-4e3d-ac5b-cdd4c1925253" x="297" y="321" width="268" height="12"/>
					<box leftPadding="5"/>
					<textElement verticalAlignment="Middle">
						<font size="5" isBold="true"/>
					</textElement>
					<text><![CDATA[[개인(신용)정보의 선택적인 수집ㆍ이용에 관한 사항]]]></text>
