				<staticText>
					<reportElement uuid="6aa6d301-35ec-4a12-8197-ffade4dc6c60" x="297" y="273" width="267" height="15"/>
					<box leftPadding="5">
						<topPen lineWidth="1.0"/>
						<leftPen lineWidth="1.0"/>
