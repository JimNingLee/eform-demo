					<text><![CDATA[제공 및 변경에 관한 세부사항]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_42020190" mode="Opaque" x="134" y="523" width="413" height="27" forecolor="#000000" backcolor="#FFFFFF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
