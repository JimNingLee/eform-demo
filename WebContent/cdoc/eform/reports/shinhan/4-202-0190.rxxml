				<staticText>
					<reportElement uuid="7784717c-5d92-430d-8ae3-6ebc587c112f" key="" style="Defaultback_42020190" mode="Transparent" x="19" y="563" width="60" height="97" forecolor="#000000" backcolor="#E8E8F0">
