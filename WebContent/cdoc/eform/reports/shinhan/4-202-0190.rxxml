				</staticText>
				<staticText>
					<reportElement uuid="83c0418e-578e-4d9b-b47d-0a972a62a4b2" x="500" y="9" width="42" height="39">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.0"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
