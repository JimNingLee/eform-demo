					<text><![CDATA[제공받은 자의 개인
(신용)정보 보유 · 이용기간]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_42020190" mode="Opaque" x="134" y="550" width="413" height="22" forecolor="#000000" backcolor="#FFFFFF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
