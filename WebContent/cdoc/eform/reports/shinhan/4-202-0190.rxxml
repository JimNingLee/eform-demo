					<text><![CDATA[동의를 거부할 권리 및 동의
를 거부할 경우의 불이익]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_42020190" mode="Opaque" x="134" y="572" width="413" height="22" forecolor="#000000" backcolor="#FFFFFF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="2">
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle">
						<font size="6" isBold="false"/>
					</textElement>
					<text><![CDATA[위 개인(신용)정보의 제공에 관한 동의는 계약의 체결 및 이행을 위하여 필수적이므로, 위 사항에 동의하셔야만 (금융)거래관계의 설정 및 유지가 가능
합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_42020190" mode="Opaque" x="34" y="594" width="100" height="20" forecolor="#000000" backcolor="#CCCCCC">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box>
						<leftPen lineWidth="0.75"/>
