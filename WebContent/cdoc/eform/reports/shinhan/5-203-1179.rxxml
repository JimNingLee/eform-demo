					<textElement/>
					<text><![CDATA[○ 당사의 상품·서비스 소개 및 사은 판촉 행사 등의 안내
○ 당사 내부의 시장조사 및 상품개발·연구 등]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="da7218cc-1527-4c40-a97d-74955e6c077e" style="Default" mode="Transparent" x="54" y="377" width="471" height="11">
