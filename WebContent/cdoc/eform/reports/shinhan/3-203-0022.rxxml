				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Default" x="18" y="79" width="543" height="140">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box topPadding="2" leftPadding="5" bottomPadding="2" rightPadding="5">
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
