					<text><![CDATA[보증료 자동이체 신청서]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Default" x="21" y="644" width="140" height="18">
