						<rightPen lineWidth="0.0"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle"/>
					<text><![CDATA[※ 본 동의 이전에 발생한 개인(신용)정보도 포함됩니다. ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Defaultback" mode="Transparent" x="22" y="329" width="93" height="34">
