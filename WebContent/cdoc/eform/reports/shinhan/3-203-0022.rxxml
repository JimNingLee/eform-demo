						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.0"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle"/>
					<text><![CDATA[수집이용 목적 ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Defaultback" mode="Transparent" x="115" y="130" width="442" height="43">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="3">
						<topPen lineWidth="0.0"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle"/>
					<text><![CDATA[■ 공사의 상품 및 서비스 홍보 및 판매 권유
■ 공사의 경품지급, 사은행사 등 고객의 편의 제공
■ 공사의 시장조사 및 상품 개발·연구
■ 고객 만족도 조사 등]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Defaultback" mode="Transparent" x="22" y="173" width="93" height="77">
