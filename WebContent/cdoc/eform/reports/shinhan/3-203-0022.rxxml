					</reportElement>
					<box>
						<bottomPen lineWidth="0.75"/>
					</box>
					<textElement verticalAlignment="Middle" markup="none">
						<font isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA["신청인(신용보증 의뢰인) :             "+ ("1".equals($F{item6}) ? $F{item1} : "")]]></textFieldExpression>
				</textField>
				<staticText>
