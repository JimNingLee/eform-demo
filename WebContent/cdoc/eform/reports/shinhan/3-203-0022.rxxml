					<textElement textAlignment="Left" verticalAlignment="Middle"/>
					<text><![CDATA[■ 개인식별정보 외에 거래신청서에 기재된 정보 또는 고객이 제공한 정보
   ▶ 주거 및 가족사항, 거주기간, 세대구성 등]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7af3a2a1-43f5-44b1-88c6-9f3cb0ee5f03" style="Defaultback" mode="Transparent" x="115" y="316" width="442" height="13">
