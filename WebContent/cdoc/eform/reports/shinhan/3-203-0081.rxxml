					<text><![CDATA[LIG 손해보험 주식회사 / 캡소프트 귀중]]></text>
				</staticText>
				<rectangle>
					<reportElement uuid="728a44e3-e937-444d-bef3-ff1a771d064f" mode="Transparent" x="27" y="109" width="525" height="176">
						<property name="com.cabsoft.rx.export.html.zindex" value="-98"/>
					</reportElement>
