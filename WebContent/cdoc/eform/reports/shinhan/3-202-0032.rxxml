						<font size="8" isBold="true"/>
					</textElement>
					<text><![CDATA[고유식별정보 동의여부]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" mode="Opaque" x="407" y="320" width="147" height="15" forecolor="#000000" backcolor="#CCCCCC"/>
					<box leftPadding="0" rightPadding="3"/>
					<textElement textAlignment="Right" verticalAlignment="Middle" markup="html">
						<font size="8" isBold="true"/>
					</textElement>
					<text><![CDATA[(동의함      동의하지 않음     )]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" mode="Opaque" x="143" y="320" width="264" height="15" forecolor="#000000" backcolor="#CCCCCC"/>
					<box leftPadding="3"/>
					<textElement verticalAlignment="Middle" markup="html">
						<font size="8" isBold="false"/>
					</textElement>
					<text><![CDATA[고유식별정보 : [주민등록번호, 여권번호, 외국인등록번호]]]></text>
				</staticText>
