					</textElement>
					<text><![CDATA[고유식별정보 동의여부]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" mode="Opaque" x="41" y="632" width="513" height="24" forecolor="#000000" backcolor="#FFFFFF"/>
