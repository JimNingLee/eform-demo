	<group name="report">
		<groupExpression><![CDATA[$V{PAGE_NUMBER}]]></groupExpression>
		<groupHeader>
			<band height="760">
				<staticText>
					<reportElement uuid="0c08f28a-5261-4d31-8cb8-76e53ae51db1" style="Default" x="49" y="29" width="179" height="20">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<textElement>
						<font size="13" isBold="true"/>
					</textElement>
					<text><![CDATA[<붙임> 신용보증신청서 양식]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="0c08f28a-5261-4d31-8cb8-76e53ae51db1" style="Default" x="49" y="56" width="480" height="22">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<textElement textAlignment="Center">
						<font size="13" isBold="true"/>
					</textElement>
					<text><![CDATA[신용보증신청서(공통양식*)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="0c08f28a-5261-4d31-8cb8-76e53ae51db1" style="Default" x="49" y="78" width="480" height="15">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<textElement textAlignment="Center">
						<font size="9" isBold="false"/>
					</textElement>
					<text><![CDATA[*집단전세자금, 모기지신용, 건축개량자금보증은 다음 장의 별도 양식 이용
]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="0c08f28a-5261-4d31-8cb8-76e53ae51db1" style="Default" x="49" y="93" width="166" height="17">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<textElement>
						<font size="11" isBold="true"/>
					</textElement>
					<text><![CDATA[한국주택금융공사 앞]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="0c08f28a-5261-4d31-8cb8-76e53ae51db1" style="Default" x="49" y="114" width="480" height="42">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="10">
						<topPen lineWidth="0.75" lineStyle="Double"/>
						<leftPen lineWidth="0.75" lineStyle="Double"/>
						<bottomPen lineWidth="0.75" lineStyle="Double"/>
						<rightPen lineWidth="0.75" lineStyle="Double"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[※ 본 신청서는 금융기관 직원의 도움을 받아 작성하시기 바랍니다.
※ 아래 기재내용은 귀하의 신용평가에 반영되오니 누락되는 부분 없이 사실대로 기재하시기 바랍니다.
※ 다음 중 어느 하나 이상 해당시 보증료율 0.1% 할인혜택 부여(다만, 집단중도금보증, 연계중도금보증, 구상채권회수보증은 적용 제외)
  - 신혼가구(혼인기간 5년 이내), 다자녀가구(만 20세 미만 자녀 3명 이상), 다문화가구, 연소득, 2,500만원 이하 입증자]]></text>
				</staticText>
				<rectangle>
					<reportElement uuid="d2eb387b-a300-4e14-9d94-f033cd809ba3" mode="Transparent" x="49" y="162" width="480" height="128">
						<property name="com.cabsoft.rx.export.html.zindex" value="-99"/>
					</reportElement>
					<graphicElement>
						<pen lineStyle="Double"/>
					</graphicElement>
				</rectangle>
