						<font isBold="false"/>
					</textElement>
					<text><![CDATA[고유식별정보
동의여부]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="341c5e3a-dc94-4f64-968b-74084587c4ac" style="styborder" x="107" y="753" width="457" height="13"/>
