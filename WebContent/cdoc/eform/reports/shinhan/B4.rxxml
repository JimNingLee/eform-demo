					<textElement>
						<font isBold="false"/>
					</textElement>
					<text><![CDATA[ 공사가 위 목적으로 다음과 같은 본인의 고유식별정보를 수집·이용하는 것에 동의합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="341c5e3a-dc94-4f64-968b-74084587c4ac" style="styborder" x="107" y="766" width="279" height="13"/>
