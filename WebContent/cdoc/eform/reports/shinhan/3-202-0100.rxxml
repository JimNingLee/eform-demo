					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font size="7" isBold="true"/>
					</textElement>
					<text><![CDATA[수집 · 이용에 관한 사항]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_32020100" mode="Opaque" x="32" y="139" width="66" height="18" forecolor="#000000" backcolor="#CCCCCC">
