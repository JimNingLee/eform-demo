				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_32020100" mode="Opaque" x="98" y="599" width="447" height="25" forecolor="#000000" backcolor="#FFFFFF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
