					</textElement>
					<text><![CDATA[)                                    ■ 선택적 정보]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="2cf6d53a-3e73-4d8c-b1e8-9fb0463b2526" style="Default_32020100" mode="Transparent" x="415" y="333" width="29" height="20">
						<property name="com.cabsoft.rx.export.html.zindex" value="2"/>
					</reportElement>
					<textElement verticalAlignment="Middle">
						<font size="7" isBold="true"/>
