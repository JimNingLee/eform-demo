				<staticText>
					<reportElement uuid="73b5129a-3df7-4877-bcee-ec5ba5770436" style="Defaultback_32020100" mode="Opaque" x="34" y="391" width="66" height="113" forecolor="#000000" backcolor="#CCCCCC">
