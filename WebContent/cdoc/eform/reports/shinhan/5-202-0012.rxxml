						<font isBold="true"/>
					</textElement>
					<text><![CDATA[신용등급개선, 자산증가 또는 부채감소 등)에는 증빙자료를]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="98dec096-3126-4fe8-9f39-9548deaedad4" style="Default" x="319" y="619" width="207" height="11">
