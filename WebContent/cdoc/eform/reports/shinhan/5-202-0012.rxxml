					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle" markup="none">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[되는 날을 등록사유 발생일로 하여 그 때로부터 10일 이내]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="4c6ab4b1-7e45-443f-96e2-0dc3a51818ef" style="Default" x="74" y="86" width="114" height="12">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box>
						<bottomPen lineWidth="0.75"/>
					</box>
