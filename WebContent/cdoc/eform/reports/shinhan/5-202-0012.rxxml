					<textElement textAlignment="Justified" verticalAlignment="Middle" markup="none"/>
					<text><![CDATA[■ 중도상환수수료(율) :]]></text>
				</staticText>
				<textField>
					<reportElement uuid="18c0c0d8-76ef-44f5-a7c5-a9c88792762e" style="Default" x="393" y="635" width="8" height="12" forecolor="#0000FF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
