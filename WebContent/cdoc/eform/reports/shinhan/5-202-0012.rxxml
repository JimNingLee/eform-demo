						<font isBold="true"/>
					</textElement>
					<text><![CDATA[대출원금, 이자 등을 3개월 이상 연체한 경우에는 3개월이]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="4c6ab4b1-7e45-443f-96e2-0dc3a51818ef" style="Default" x="74" y="73" width="215" height="12">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
