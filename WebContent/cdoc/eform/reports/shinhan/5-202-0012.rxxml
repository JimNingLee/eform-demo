					</textElement>
					<text><![CDATA[채무변제의무 사유에 해당되어 기한의 이익(미리 정한기간]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="4c6ab4b1-7e45-443f-96e2-0dc3a51818ef" style="Default" x="316" y="128" width="149" height="11">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
