					</reportElement>
				</rectangle>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_5pt" mode="Opaque" x="52" y="643" width="16" height="67" forecolor="#000000" backcolor="#E7F8FC">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.5" lineColor="#00A2DF"/>
						<leftPen lineWidth="0.5" lineColor="#00A2DF"/>
						<bottomPen lineWidth="0.0" lineColor="#00A2DF"/>
						<rightPen lineWidth="0.0" lineColor="#00A2DF"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="3" spacingBefore="5"/>
					</textElement>
					<text><![CDATA[(예시)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_5pt" mode="Opaque" x="68" y="643" width="206" height="67" forecolor="#000000" backcolor="#E7F8FC">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.5" lineColor="#00A2DF"/>
						<leftPen lineWidth="0.0" lineColor="#00A2DF"/>
						<bottomPen lineWidth="0.0" lineColor="#00A2DF"/>
						<rightPen lineWidth="0.5" lineColor="#00A2DF"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="3" spacingBefore="3"/>
					</textElement>
					<text><![CDATA[원금 1억2천만원,분할상환 원리금(원금과 이자) 매월 150만원, 약정이자율 연 5%인 대출의 분할상환 원리금(원금과 이자)을 미납하여 연체가 발생하고, 연체발생후 2개월 시점에 납부할 경우 연체이자         ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_5pt" mode="Opaque" x="52" y="493" width="220" height="64" forecolor="#000000" backcolor="#E7F8FC">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.5" lineColor="#00A2DF"/>
						<leftPen lineWidth="0.5" lineColor="#00A2DF"/>
						<bottomPen lineWidth="0.0" lineColor="#00A2DF"/>
						<rightPen lineWidth="0.5" lineColor="#00A2DF"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="3" spacingBefore="5"/>
					</textElement>
					<text><![CDATA[(예시) 원금 1억2천만원, 약정이자율 연 5%인 대출의 원금상환일에 원급을 미납하
          여 연체가 발생하고, 연체발생후 2개월 시점에 납부할 경우 연체이자]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="56" y="24" width="244" height="17">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[때 적용될 최고 약정한도미사용 수수료를 감안한 실질유효금리의 계산 결과를 참고목
적으로 안내드리고 있습니다.]]></text>
				</staticText>
				<staticText>
