					<textElement markup="styled">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[7. 대출 상환방법]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="185" width="20" height="10">
