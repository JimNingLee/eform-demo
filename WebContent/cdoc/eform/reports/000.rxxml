						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="65" y="185" width="212" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[만기 일시상환방식 : 대출기간 만기일에 전액 상환]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="65" y="195" width="212" height="15">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[분할상환방식 : 여신개시일로부터 익월 또는 일정기간동안 거치후 만기일
까지 분할하여 상환
]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="195" width="20" height="15">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="false"/>
						<paragraph leftIndent="10"/>
					</textElement>
