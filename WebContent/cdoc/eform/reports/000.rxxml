					<reportElement uuid="a4b8100d-ad15-489a-b599-c823e9f345f2" mode="Opaque" x="32" y="155" width="518" height="629" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="2"/>
					</reportElement>
				</rectangle>
				<staticText>
					<reportElement uuid="bd400ff7-9759-44d3-be33-ae2a3d3f87e9" style="fontSize_6pt" x="370" y="20" width="180" height="11">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled"/>
					<text><![CDATA[심의번호 : 2014.05.02 준법-0553 심의필(유효기간 : 2016. 12. 31)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_8pt" x="42" y="73" width="498" height="24">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<font fontName="바탕체" size="8"/>
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[본인은 주식회사 우리은행과 대출거래를 함에 있어 은행직원과 상담하여 아래에서 설명한 내용을 포함하여 대출거래의 주요내용 및
고객부담비용에 대하여 충분히 설명을 듣고 이해하였음을 확인합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_8pt" x="42" y="119" width="502" height="27">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[이 설명서는 은행이용자의 상품에 대한 이해를 돕고 약관의 중요내용을 알려드리기 위한 참고자료이며, 실제 계약은 대출거래약정서(기업
용), 여신거래기본약관(기업용)이 적용됩니다. 계약을 신청하는 경우 약관이, 계약을 체결하는 경우 계약서류가 교부됩니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="Default" x="45" y="35" width="483" height="28" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement textAlignment="Center" verticalAlignment="Middle" markup="styled">
						<font size="20" isBold="true"/>
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[기업대출상품설명서]]></text>
				</staticText>
				<textField>
					<reportElement uuid="088e96c3-36f5-43b7-8e13-bcb0899b62dd" style="fontSize_8pt" x="42" y="154" width="487" height="15" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<font isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA["1. 상품 개요 및 상품의 특성"]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_8pt" x="45" y="284" width="234" height="15" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[2. 거래구분]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="301" width="54" height="18">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>개별거래 : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="319" width="54" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>한도거래 : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="99" y="301" width="180" height="18">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Middle" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[약정액 범위 내에서 일괄하여 대출이 발생하고 상환한 금액을
재사용할 수 없는 방식]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="99" y="319" width="180" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Middle" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[약정한 한도금액 범위 내에서 동일과목의 대출을 자유롭게 재사
용하고 여신기간 만료일에 한도금액을 상환하는 방식 (개별거래
에 비해 상품마다 별도 가산금리가 부과되어 금리수준이 높음)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="286" width="242" height="20">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>고객에게 적용되는 대출금리는 고객의 신용등급 및 담보유무 등에
    따라 달리 적용됩니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_8pt" x="45" y="362" width="234" height="15" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[3. 대출 이자율]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_8pt" x="296" y="305" width="242" height="15" forecolor="#00A2DF">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement markup="styled">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[4. 수수료 등 비용]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="99" y="379" width="180" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Middle" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[여신실행시 결정한 금리가 약정기간동안 동일하게 적용되는
금리입니다. 다만, 여신실행일 현재 은행에서 고지하는 기준
금리의 변동에 따라 금리차이가 발생할 수 있습니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="99" y="404" width="180" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Middle" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[대출약정 기간내에 기준금리가 변경되리 경우 당해 대출금리가
변경되는 금리로서 기준 금리가 인상될 경우 고객의 이자 부담
이 증가될 수 있습니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="404" width="54" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>변동금리 : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="45" y="379" width="54" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■</font> 고정금리 :  ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="320" width="85" height="11">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>중도상환수수료(율) : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="330" width="24" height="12">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="18"/>
					</textElement>
					<text><![CDATA[▶]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="320" y="330" width="218" height="12">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true" isUnderline="true"/>
					</textElement>
					<text><![CDATA[대출의 상환기일이 도래하기 전에 대출금을 상환할 경우 고객이 부담]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="310" y="341" width="228" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[하는 금액]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="310" y="352" width="228" height="25">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[(예시) 대출만기전 1억원 상환할 경우 중도상환수수료는?
수수료율 1.5%, 3년만기대출 2년 경과후 중도상환 가정시 :
   1억원 X 1.5% X 365/1095)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="379" width="90" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>한도약정수수료(율) : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="389" width="24" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="18"/>
					</textElement>
					<text><![CDATA[▶]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="320" y="389" width="218" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[대출한도금액 X 한도약정수수료율 = 한도약정수수료]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="419" width="81" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>기타수수료 : 항목]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="447" y="419" width="15" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[금액]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="428" width="242" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font isBold="true"/>
						<paragraph leftIndent="10"/>
					</textElement>
					<text><![CDATA[<font color="#00A2DF">■ </font>근저당권설정비용]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="312" y="438" width="62" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[국민주택채권매입비 : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="312" y="448" width="226" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[등록면허세, 지방교육세, 등기신청수수료 및 법무사수수료 : ]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="324" y="468" width="214" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[말소(감액)등기를 하는 경우 고객이 부담합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_7pt" x="296" y="468" width="28" height="10">
						<property name="com.cabsoft.rx.export.html.zindex" value="10"/>
					</reportElement>
					<textElement textAlignment="Right" verticalAlignment="Top" markup="styled">
						<paragraph leftIndent="8"/>
					</textElement>
					<text><![CDATA[▶]]></text>
