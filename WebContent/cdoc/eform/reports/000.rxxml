				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" mode="Opaque" x="231" y="668" width="35" height="11" forecolor="#000000" backcolor="#C1EFFB">
