				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="65" y="210" width="212" height="26">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<textElement verticalAlignment="Top" markup="styled">
						<font fontName="바탕"/>
					</textElement>
					<text><![CDATA[통장대출 형식의 한도거래대출 : 한도거래대출 내에서 자유로이 상환하
며, 대출 만기일에 전액 상환(이자원가시 대출원금에 포함되어 익월부터
이자가 부과됨)]]></text>
				</staticText>
