					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_5pt" mode="Opaque" x="65" y="156" width="198" height="16" forecolor="#000000" backcolor="#E7F8FC">
						<property name="com.cabsoft.rx.export.html.zindex" value="3"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.5" lineColor="#00A2DF"/>
						<leftPen lineWidth="0.5" lineColor="#00A2DF"/>
						<bottomPen lineWidth="0.5" lineColor="#00A2DF"/>
						<rightPen lineWidth="0.5" lineColor="#00A2DF"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle" markup="styled">
						<paragraph leftIndent="5"/>
					</textElement>
					<text><![CDATA[□ 통장대출의 경우 매일의 적수에 이자를 계산하는 방법으로 이자를 계산합니다.
□ 매일의 적수 = 마감잔액 + (일중최고잔액 - 개시잔액 또는 마감 잔액 중 큰금액)]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="b65e489d-7875-46a4-be41-23a771dad4a5" style="fontSize_6pt" x="54" y="146" width="220" height="10">
