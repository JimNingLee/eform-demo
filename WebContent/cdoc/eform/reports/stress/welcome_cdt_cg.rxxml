				</staticText>
				<textField isBlankWhenNull="true">
					<reportElement uuid="b9757fa3-90aa-41d9-b4d7-77dc7e59c3a1" x="416" y="188" width="60" height="35">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.75" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.0" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
