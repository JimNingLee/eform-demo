						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
						<leftPen lineWidth="0.75" lineColor="#E36C0A"/>
						<bottomPen lineWidth="0.75" lineColor="#E36C0A"/>
					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font size="8"/>
					</textElement>
					<text><![CDATA[대부중개업자가 중개수수료를 고객으로부터 받는 것이 불법임을 설명 들었습니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="391" y="188" width="25" height="35" backcolor="#FDE9D9">
