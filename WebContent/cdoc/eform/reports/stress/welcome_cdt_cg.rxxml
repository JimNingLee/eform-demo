					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="283" width="555" height="17" backcolor="#FDE9D9">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="5">
						<topPen lineWidth="0.0" lineColor="#E36C0A"/>
