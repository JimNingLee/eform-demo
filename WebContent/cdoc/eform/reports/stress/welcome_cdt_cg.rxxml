					</textElement>
					<text><![CDATA[대부거래 약관]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="7788f2df-666c-4f97-bfb4-3bedab2b8760" mode="Transparent" x="0" y="43" width="275" height="15" backcolor="#FDE9D9"/>
