						<font size="7" isBold="true"/>
					</textElement>
					<text><![CDATA[동의하지 않음]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="53e27325-078f-4d90-bad4-246be9427ca6" mode="Transparent" x="424" y="541" width="30" height="10" forecolor="#FF0000" backcolor="#FFFFFF">
						<property name="com.cabsoft.rx.export.html.zindex" value="1"/>
					</reportElement>
					<box leftPadding="0" rightPadding="0"/>
					<textElement textAlignment="Justified" verticalAlignment="Top">
						<font size="7" isBold="true"/>
					</textElement>
