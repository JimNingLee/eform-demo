				<textField>
					<reportElement uuid="74f50657-26c7-40c1-abca-2d8459fe6774" x="188" y="662" width="321" height="20"/>
					<textElement>
						<font size="9"/>
					</textElement>
					<textFieldExpression><![CDATA["은 설계사 아무개에게 주요 내용을 설명 받았습니다. 이에 서명합니다."]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement uuid="3a5f31f2-1017-4126-a45b-5d050fa649f8" style="Default" positionType="Float" mode="Transparent" x="4" y="154" width="504" height="53"/>
					<box leftPadding="10"/>
					<textElement verticalAlignment="Middle"/>
					<text><![CDATA[·과거 질병 치료사실 등을 회사에 알리지 않을 경우 보험금을 지급받지 못할 수 있습니다.
·전화 등 통신수단을 통해 보험에 가입하는 경우에는 별도의 서면질의서 없이 안내원의 질문에 답하고 이를 녹음하는 방식으로  계약전 알릴의무를 이행하여야 하므로 답변시 특히 주의하셔야 합니다.]]></text>
				</staticText>
				<staticText>
					<reportElement uuid="2b8251e5-7db4-46f2-9119-c5a23e1be8e5" style="Default" positionType="Float" mode="Transparent" x="4" y="207" width="504" height="18"/>
